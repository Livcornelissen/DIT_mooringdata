import re

# ---------------------------
# Helper: get correct CTD folder (Windows-friendly)
# ---------------------------
def get_ctd_folder(CTD_base_path, description):
    """
    Determine the correct CTD folder from the mooring description.

    Parameters
    ----------
    CTD_base_path : str
        Base path containing CTD folders (CTD1412, CTD1512, ...)
    description : str
        NetCDF 'description' attribute

    Returns
    -------
    ctd_folder : str
        Full path to CTD folder
    mooring_type : str
        DITD / DITN / DITS
    mooring_code : str
        4-digit deployment code
    """
    description = description.upper()

    # detect mooring type
    mooring_type = None
    for mt in ['DITD', 'DITN', 'DITS']:
        if mt in description:
            mooring_type = mt
            break
    if mooring_type is None:
        raise ValueError(f"Cannot determine mooring type from description: {description}")

    # extract 4-digit deployment code
    mooring_code_match = re.search(r'\b\d{4}\b', description)
    if mooring_code_match:
        mooring_code = mooring_code_match.group(0)
    else:
        raise ValueError(f"Cannot extract mooring code from description: {description}")

    # Use folder exactly like CTDxxxx
    ctd_folder = os.path.join(CTD_base_path, f"CTD{mooring_code}")
    ctd_folder = os.path.normpath(ctd_folder)  # normalize path separators for Windows

    if not os.path.exists(ctd_folder):
        raise FileNotFoundError(f"CTD folder not found: {ctd_folder}")

    return ctd_folder, mooring_type, mooring_code


# ---------------------------
# 1) Calibration function
# ---------------------------
def calibrate_mooring_nc(ds_file, CTD_base_path, cal_threshold=0.003):
    """
    Calibrate a mooring NetCDF file using start/end CTD casts.

    Parameters
    ----------
    ds_file : str
        Path to mooring NetCDF file
    CTD_base_path : str
        Base path containing CTD folders
    cal_threshold : float
        Minimum difference threshold to apply calibration (PSU)

    Returns
    -------
    ds_cal : xarray.Dataset (calibrated)
    correction : np.ndarray (depth x time)
    """
    ds = xr.open_dataset(ds_file)
    description = ds.attrs.get('description', '')
    
    # --- find folder ---
    try:
        ctd_folder, mooring_type, mooring_code = get_ctd_folder(CTD_base_path, description)
    except Exception as e:
        print(e)
        return ds, np.zeros((ds.z.size, ds.DateTime.size))

    # --- find CTD files (match only mooring type) ---
    ctd_files = sorted(glob(os.path.join(ctd_folder, f"{mooring_type}*.cnv*")))
    if len(ctd_files) == 0:
        print(f"No CTD files found for {mooring_type} in folder {ctd_folder}")
        return ds, np.zeros((ds.z.size, ds.DateTime.size))

    # --- function to read CTD ---
    def open_ctd(file):
        df = pd.read_table(file, sep=r'\s+', skiprows=2, encoding_errors='ignore')
        header = pd.read_table(file, sep=r'\s+', nrows=0, encoding_errors='ignore').columns.tolist()
        df.columns = header
        # determine depth column
        if 'depth' in df.columns:
            depth_col = 'depth'
        elif 'PrDM' in df.columns:
            depth_col = 'PrDM'
        else:
            raise ValueError(f"No depth column in CTD file {file}")
        return df, depth_col

    # --- open first and last CTDs ---
    ctd_start, depth_col = open_ctd(ctd_files[0])
    ctd_end, _ = open_ctd(ctd_files[-1])

    # --- function to get nearest CTD row for a depth ---
    def nearest_ctd(df, z_val):
        idx = (np.abs(df[depth_col] - z_val)).argmin()
        return df.iloc[idx]

    # --- apply calibration ---
    correction = np.zeros((ds.z.size, ds.DateTime.size))
    for iz, z_val in enumerate(ds.z.values):
        ct1 = nearest_ctd(ctd_start, z_val)
        ct2 = nearest_ctd(ctd_end, z_val)

        dCTD1 = ct1['S'] - float(ds.S.isel(z=iz, DateTime=0))
        dCTD2 = ct2['S'] - float(ds.S.isel(z=iz, DateTime=-1))

        N = ds.DateTime.size
        t = np.arange(N)

        if abs(dCTD1) <= cal_threshold and abs(dCTD2) <= cal_threshold:
            corr = np.zeros(N)
        else:
            corr = dCTD1 + (dCTD2 - dCTD1) * t / (N - 1)

        ds['S'][iz, :] = ds.S.isel(z=iz) + corr
        correction[iz, :] = corr

    return ds, correction

