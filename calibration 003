import matplotlib.pyplot as plt
import numpy as np

def plot_mooring_calibration(ds_orig, ds_cal, title=None):
    """
    Plot original and calibrated salinity for each depth in a mooring dataset.

    Parameters
    ----------
    ds_orig : xarray.Dataset
        Original dataset
    ds_cal : xarray.Dataset
        Calibrated dataset
    title : str, optional
        Plot title
    """
    z_vals = ds_orig.z.values
    time = ds_orig.DateTime.values

    plt.figure(figsize=(10, 6))
    for iz, z_val in enumerate(z_vals):
        plt.plot(time, ds_orig.S.isel(z=iz), label=f'Orig z={z_val} m', linestyle='--')
        plt.plot(time, ds_cal.S.isel(z=iz), label=f'Cal z={z_val} m', linestyle='-')

    plt.xlabel('DateTime')
    plt.ylabel('Salinity [PSU]')
    plt.title(title if title else 'Mooring Salinity Calibration')
    plt.legend(loc='best', fontsize=8)
    plt.grid(True)
    plt.tight_layout()
    plt.show()



