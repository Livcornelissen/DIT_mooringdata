# ---------- doy_DITD with uncertainty shading ----------
def doy_DITD(var, title, units, d):
    years = np.arange(2017,2025)
    fig, ax = plt.subplots(figsize=(11,3), layout='constrained')
    c = 0
    for year in years:
        if year == 2017:
            ds = DITD.sel(time = slice(datetime(year,2,1),datetime(year,12,31)))
        else:
            ds = DITD.sel(time = slice(datetime(year,1,1),datetime(year,12,31)))

        days = ds.groupby('time.dayofyear').median(dim = 'time')

        # select the DataArray for plotting
        try:
            da = days[var].sel(depth = d)
        except Exception:
            # if selection fails, try without depth (e.g. instrument time-series)
            da = days[var]

        # plot the median line
        da.plot(label = str(year), ax = ax, c = colors[c])

        # compute and plot uncertainty band for this year
        try:
            x, lower, upper = compute_bands(da, var)
            ax.fill_between(x, lower, upper, alpha=0.15, color=colors[c])
        except Exception:
            pass

        c += 1

    ax.tick_params(axis='both', which='major', labelsize=15)
    xticks = np.cumsum([0,31,28,31,30,31,30,31,31,30,31,30])
    xlabels = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec']
    ax.set_xticks(xticks, xlabels)
    ax.set_title(f'depth = {d} m', fontsize=15)
    ax.set_xlim(0,365)

    if var == 'P':
        ax.invert_yaxis()
    else:
        # climatology median + band
        try:
            clim = DITD[var].sel(depth = d).groupby('time.dayofyear').median(dim = 'time')
        except Exception:
            clim = DITD[var].groupby('time.dayofyear').median(dim = 'time')

        clim.plot(ax = ax, label = 'Multi-year mean', c = 'black', linewidth = 3)
        try:
            x_clim, lower_clim, upper_clim = compute_bands(clim, var)
            ax.fill_between(x_clim, lower_clim, upper_clim, alpha=0.2, color='black')
        except Exception:
            pass

    ax.set_ylabel(f'{title} {units}', fontsize=15)
    ax.set_xlabel(' ')

    lines = [Line2D([0], [0], color=c, linewidth=1.1, linestyle='-') for c in colors]
    labels_local = ['2017','2018','2019','2020','2021','2022','2023','2024']
    fig.legend(lines, labels_local, bbox_to_anchor=(1.01,1.0), loc='upper left', fontsize=12)
    plt.suptitle('DITD ', fontsize = 18)
    plt.savefig(figure_path + 'data_publication/DITD_' + var + '_uncertainty.png',bbox_inches='tight')
    plt.show()
    plt.close('all')



