    for d in range(row):
        ds[variable].sel(depth = depth[d]).plot(ax=ax[d])
        ax[d].set_xlim(ds.time[d],ds.time[-1])
        ax[d].set_xlabel(' ')
        ax[d].set_title(title[d]+r', depth $\approx$'+str(depth[d]))
    
    plt.suptitle(suptitle, fontsize = 15)     
    
    
