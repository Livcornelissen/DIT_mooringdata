        # print(len(depth) - row)
        fig, ax = plt.subplots(nrows = (len(depth)-row),ncols = 1,\
            figsize = (11,3*(len(depth)-row)), sharex = True,layout='constrained')
        #
        for d in range(row,len(depth)):
            ds[variable].sel(depth = depth[d]).plot(ax=ax[d-row])
