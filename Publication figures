# ---------- helper to compute uncertainty bands ----------
def compute_bands(da, varname):
    """
    da: xarray DataArray indexed by dayofyear (1..365) or similar
    returns (x, lower, upper) as numpy arrays suitable for ax.fill_between
    """
    # get x axis (dayofyear coordinate if present)
    if 'dayofyear' in da.coords:
        x = da['dayofyear'].values
    else:
        # fallback: numeric index starting at 1
        x = np.arange(1, da.size + 1)

    vals = da.values.astype(float)

    if varname == 'SA':
        lower = vals - 0.003
        upper = vals + 0.003
    elif varname == 'CT':
        lower = vals - 0.002
        upper = vals + 0.002
    elif varname == 'P':
        uncert = 0.001 * np.abs(vals)   # 0.1% -> 0.001 factor
        lower = vals - uncert
        upper = vals + uncert
    elif varname == 'spe':
        uncert = 0.01 * np.abs(vals) + 0.5  # ±1% ±0.5 cm/s
        lower = vals - uncert
        upper = vals + uncert
    else:
        # generic tiny band: +/- 1% (fallback)
        uncert = 0.01 * np.abs(vals)
        lower = vals - uncert
        upper = vals + uncert

    return x, lower, upper



