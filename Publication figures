def SA_CT(ds):
    # Remove NaNs first
    SP = ds['S'].where(ds['S'].notnull())
    t_in = ds['T'].where(ds['T'].notnull())
    P_in = ds['P'].where(ds['P'].notnull())
    
    SA_vals = gsw.SA_from_SP(SP.values, P_in.values, lon, lat)
    CT_vals = gsw.CT_from_t(SA_vals, t_in.values, P_in.values)
    
    SA_da = xr.DataArray(SA_vals, coords=ds['S'].coords, dims=ds['S'].dims,
                         name='SA', attrs={'long_name':'Absolute Salinity', 'units':'g kg-1'})
    CT_da = xr.DataArray(CT_vals, coords=ds['T'].coords, dims=ds['T'].dims,
                         name='CT', attrs={'long_name':'Conservative Temperature', 'units':'degC'})
    
    ds = ds.assign(SA=SA_da, CT=CT_da)
    return ds

