def doy_plot(DS, var, depth, title, ylabel, units):
    plt.close('all')
    fig, ax = plt.subplots(nrows = len(depth), figsize = (11,len(depth)*3), sharex = True, layout='constrained')
    pos = 0

    for d in depth:
        c = 0
        for year in years:
            if year == 2014:
                ds = DS.sel(time = slice(datetime(year,12,12),datetime(year,12,31)))
            else:
                ds = DS.sel(time = slice(datetime(year,1,1),datetime(year,12,31)))

            if d == 668 and year == 2019:
                pass

            elif d == 668 and year == 2020:
                days = ds.sel(time = slice(datetime(2020,3,20),datetime(2020,12,31))).groupby('time.dayofyear').median(dim = 'time')
            else:
                days = ds.groupby('time.dayofyear').median(dim = 'time')

            # median line
            median = days[var].sel(depth = d)
            median.plot(label = str(year), ax = ax[pos], c = colors[c])

            # compute uncertainty bands depending on variable and plot shaded region
            x = np.arange(1, len(median['dayofyear'].values)+1)

            if var == 'SA':  # salinity, asymmetric bounds provided by you: lower=0.003, upper=0.01
                lower = median - 0.01
                upper = median + 0.01
                ax[pos].fill_between(x, lower, upper, alpha=0.15, color=colors[c])
            elif var == 'CT':  # conserved temperature, SBE temperature accuracy ±0.002 °C
                lower = median - 0.002
                upper = median + 0.002
                ax[pos].fill_between(x, lower, upper, alpha=0.15, color=colors[c])
            elif var == 'P':  # pressure, use ±0.1% of measured value (proxy for ±0.1% full scale)
                # ensure non-negative and handle NaNs
                uncert = 0.001 * np.abs(median)
                lower = median - uncert
                upper = median + uncert
                ax[pos].fill_between(x, lower, upper, alpha=0.15, color=colors[c])
            elif var == 'spe':  # speed, AQD/Aquadopp spec: ±1% of measured value ±0.5 cm/s
                # convert to numpy arrays to compute
                median_vals = median.values.astype(float)
                uncert = 0.01 * np.abs(median_vals) + 0.5  # same units as median (cm/s)
                lower = median_vals - uncert
                upper = median_vals + uncert
                # convert back to xarray-like if needed — for plotting with fill_between we pass numpy arrays
                ax[pos].fill_between(x, lower, upper, alpha=0.15, color=colors[c])
            else:
                # for other variables do nothing (or add a generic small band)
                pass

            ax[pos].set_xlabel(' ')
            ax[pos].tick_params(axis='both', which='major', labelsize=15)
            c += 1

        # add climatology median and its band
        if var != 'P':
            clim = DS[var].sel(depth = d).groupby('time.dayofyear').median(dim = 'time')
            clim.plot(ax = ax[pos], label = 'Multi-year mean', c = 'black', linewidth = 3)
            # add climatology uncertainty band using same rules
            x_clim = np.arange(1, len(clim['dayofyear'].values)+1)
            if var == 'SA':
                lower_clim = clim - 0.01
                upper_clim = clim + 0.01
                ax[pos].fill_between(x_clim, lower_clim, upper_clim, alpha=0.2, color='black')
            elif var == 'CT':
                lower_clim = clim - 0.002
                upper_clim = clim + 0.002
                ax[pos].fill_between(x_clim, lower_clim, upper_clim, alpha=0.2, color='black')
            elif var == 'spe':
                med = clim.values.astype(float)
                uncert = 0.01 * np.abs(med) + 0.5
                ax[pos].fill_between(x_clim, med - uncert, med + uncert, alpha=0.2, color='black')

        ax[pos].set_title(f'depth = {d} m', fontsize=15)
        ax[pos].set_ylabel(ylabel + units, fontsize = 15)
        pos += 1

    # x-axis formatting (day-of-year ticks)
    xticks = np.cumsum([0,31,28,31,30,31,30,31,31,30,31,30])
    xlabels = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec']
    ax[len(depth)-1].set_xticks(xticks, xlabels)
    ax[len(depth)-1].set_xlim(0,365)

    if var == 'P':
        # invert axes if you want pressure increasing downward (your original code did some inversions)
        if len(depth) > 1:
            try:
                ax[1].set_ylim(290,269)
            except Exception:
                pass
        ax[0].invert_yaxis()
        if len(depth) > 2:
            ax[2].invert_yaxis()

    lines = [Line2D([0], [0], color=c, linewidth=1.1, linestyle='-') for c in colors]
    fig.legend(lines, labels, bbox_to_anchor=(1.01,1.0), loc='upper left', fontsize=18)
    plt.suptitle(title, fontsize = 22)
    plt.savefig(figure_path + 'data_publication/DITN_' + var + '_uncertainty.png',bbox_inches='tight')
    plt.show()

